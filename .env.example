# IM System v3 - Intelligent Markets
# Copia este archivo como .env y completa los valores

# Claude API (console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Telegram Bot (@BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=ID1,ID2

# Meta Ads (developers.facebook.com)
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=act_
META_APP_ID=
META_APP_SECRET=

# Gmail para envio de emails
IM_EMAIL=
IM_EMAIL_PASSWORD=

# Google Maps (console.cloud.google.com)
GOOGLE_MAPS_API_KEY=

# Apollo.io para leads
APOLLO_API_KEY=

# Wompi pagos (dashboard.wompi.co)
WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=
WOMPI_EVENTS_SECRET=
WOMPI_ENV=production

# Cal.com links
CAL_EMPRESAS=
CAL_MUSIC=

# Modo: interno o saas
MODO=interno
JWT_SECRET=cambiar-en-produccion
